# =============================================================
#  IdealOS — Variáveis de Ambiente
#  Copie este arquivo como .env e preencha os valores
# =============================================================

# ----- OBRIGATÓRIO -----

# Sua chave de API do Google Gemini
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY="cole-sua-chave-aqui"

# Chave secreta para gerar tokens de login
# Gere uma nova em: https://generate-secret.vercel.app/64
# NUNCA use o valor de exemplo em producao!
SECRET_KEY="troque-por-uma-chave-forte-e-aleatoria"

# ----- BANCO DE DADOS -----

# Desenvolvimento (SQLite - nao precisa mudar):
DATABASE_URL="sqlite:///./idealos.db"

# Producao no Railway (PostgreSQL - Railway preenche automaticamente):
# DATABASE_URL="postgresql://usuario:senha@host:5432/banco"

# ----- AMBIENTE -----

# "development" em sua maquina | "production" no Railway
ENVIRONMENT="development"

# ----- ORIGENS PERMITIDAS (CORS) -----

# Desenvolvimento:
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Producao (substitua pela URL do seu app no Railway):
# ALLOWED_ORIGINS="https://seu-app.up.railway.app"

# ----- HOSTS CONFIAVEIS -----

# Desenvolvimento:
TRUSTED_HOSTS="localhost,127.0.0.1"

# Producao (substitua pelo dominio do Railway):
# TRUSTED_HOSTS="localhost,127.0.0.1,seu-app.up.railway.app"

# ----- FRONTEND -----
NODE_ENV="development"
PORT="5173"
